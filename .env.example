# PayHip Credentials
PAYHIP_EMAIL=your-email@example.com
PAYHIP_PASSWORD=your-password-here
PAYHIP_API_KEY=your-payhip-api-key

# AI Service API Keys
SUNO_API_KEY=your-suno-api-key
STABILITY_API_KEY=your-stability-api-key
OPENAI_API_KEY=your-openai-api-key

# Notifications (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Database (Optional)
DATABASE_URL=postgresql://user:password@localhost/payhip_automation

# Scheduling
SCHEDULE_TIME=0 0 * * *  # Daily at midnight

# Environment
ENV=production
DEBUG=false
